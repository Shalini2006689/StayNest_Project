<%- layout("/layouts/boilerplate") %>

  <div class="filter-row-wrapper">
    <button class="scroll-btn left" id="scrollLeft" aria-label="Scroll filters left"><i class="fa-solid fa-caret-left"></i></button>

    <div id="filters-wrap" class="filters">
      <% const categories = ["all", "Trending", "Room", "Iconic Cities", "Mountain", "Castles", "Amazing Pools", "Camping", "Farms", "Arctic", "Dome", "Boats", "Beach"]; %>
        <% const icons = {
      all: "fa-compass",
      Trending: "fa-fire",
      Room: "fa-bed",
      "Iconic Cities": "fa-city",
      Mountain: "fa-mountain",
      Castles: "fa-chess-rook",
      "Amazing Pools": "fa-person-swimming",
      Camping: "fa-tent",
      Farms: "fa-tractor",
      Arctic: "fa-snowflake",
      Dome: "fa-landmark-dome",
      Boats: "fa-ship",
      Beach: "fa-umbrella-beach"
    }; %>

    <% categories.forEach((category) => { %>
      <% const categoryKey = category === "all" ? "all" : category; %>
      <button
        class="filter <%= activeCategory === category.toLowerCase() ? 'active' : '' %>"
        data-category="<%= category.toLowerCase() %>"
        type="button"
      >
        <div><i class="fa-solid <%= icons[categoryKey] %>"></i></div>
        <p><%= category === "all" ? "All" : category %></p>
      </button>
    <% }) %>
  </div>
  
  <button class="scroll-btn right" id="scrollRight" aria-label="Scroll filters right">
    <i class="fa-solid fa-caret-right"></i>
  </button>
</div>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 mt-3 g-4" id="listingGrid">
  <% allListings.forEach((listing) => { %>
    <article
      class="listing-card"
      data-location="<%= listing.location %>"
      data-category="<%= (listing.category || 'Trending').toLowerCase() %>"
    >
      <div class="card card-listing h-100 shadow-sm">
        <a href="/listings/<%= listing._id %>" class="listing-link">
          <img src="<%= listing.image.url %>" class="card-img-top listing-img" alt="<%= listing.title %>">
          <div class="card-img-overlay"></div>
          <div class="card-body px-1 pt-2">
            <p class="card-text mb-1"><b><%= listing.title %></b></p>
            <p class="text-muted mb-1"><%= listing.location %> · <%= listing.category || "Trending" %></p>
            <p class="mb-0">&#8377;<%= Number(listing.price || 0).toLocaleString("en-IN") %> / night <i class="tax-info"> +18% GST</i></p>
          </div>
        </a>
      </div>
    </article>
  <% }) %>
</div>
    <p class="mt-3 text-muted d-none" id="noListingsMessage">No Listings match your filters </p>